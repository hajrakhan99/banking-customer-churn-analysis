    <jsScripts>
      <jsScript>
        <jsScript_type>0</jsScript_type>
        <jsScript_name>Script 1</jsScript_name>
        <jsScript_script>// TRIM TEXT FIELDS SAFELY
if(Gender != null) { Gender = Gender.trim(); }
if(City != null) { City = City.trim(); }
if(Occupation != null) { Occupation = Occupation.trim(); }
if(Account_Type != null) { Account_Type = Account_Type.trim(); }
if(Churn_Status != null) { Churn_Status = Churn_Status.trim(); }
if(Loan_Status != null) { Loan_Status = Loan_Status.trim(); }
if(Debit_Card_Usage != null) { Debit_Card_Usage = Debit_Card_Usage.trim(); }
if(Retention_Recommendation != null) { Retention_Recommendation = Retention_Recommendation.trim(); }
if(Insurance_Product != null) { Insurance_Product = Insurance_Product.trim(); }
if(Relationship_Manager_Assigned != null) { Relationship_Manager_Assigned = Relationship_Manager_Assigned.trim(); }
if(Cashback_Offer_Response != null) { Cashback_Offer_Response = Cashback_Offer_Response.trim(); }

// FIX NULL STRINGS
if(Loan_Status == null || Loan_Status.equals("")) { 
    Loan_Status = "No Loan"; 
}
if(Insurance_Product == null || Insurance_Product.equals("")) { 
    Insurance_Product = "Unknown"; 
}
if(Relationship_Manager_Assigned == null || Relationship_Manager_Assigned.equals("")) { 
    Relationship_Manager_Assigned = "No"; 
}

// FIX NULL NUMBERS
if(Mobile_App_Login_Freq == null) { Mobile_App_Login_Freq = 0.0; }
if(Reward_Points_Used == null) { Reward_Points_Used = 0.0; }
if(UPI_Transactions == null) { UPI_Transactions = 0.0; }
if(Monthly_Income == null) { Monthly_Income = -1.0; }
if(Credit_Score == null) { Credit_Score = -1.0; }

// STANDARDISE Cashback
if(Cashback_Offer_Response != null) {
    if(Cashback_Offer_Response.equals("Ignored")) { 
        Cashback_Offer_Response = "No Response"; 
    }
    if(Cashback_Offer_Response.equals("Rejected")) { 
        Cashback_Offer_Response = "Declined"; 
    }
}

</jsScript_script>
      </jsScript>
    </jsScripts>
